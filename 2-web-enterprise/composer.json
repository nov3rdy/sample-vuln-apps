{
    "name": "companyhub/portal",
    "description": "CompanyHub — internal company portal",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8",
        "phpmailer/phpmailer": "6.0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CompanyHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CompanyHub\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
